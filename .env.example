# C Learn — Configuration
# Copy this file to .env and adjust values as needed.
# All settings have sensible defaults — the platform runs without any .env file.

# ── Server ──────────────────────────────────────────────────────────
# Flask development server port
CLEARN_PORT=8765

# ── Compilation ─────────────────────────────────────────────────────
# Timeout for TCC compilation (seconds)
CLEARN_COMPILE_TIMEOUT=15

# Timeout per test case execution (seconds)
CLEARN_RUN_TIMEOUT=5

# Free-play execution timeout (seconds)
CLEARN_FREE_RUN_TIMEOUT=10

# ── Output Limits ───────────────────────────────────────────────────
# Maximum stdout capture size (characters)
CLEARN_MAX_STDOUT=10000

# Maximum stderr capture size (characters)
CLEARN_MAX_STDERR=5000

# ── Security ────────────────────────────────────────────────────────
# Enable strict security scanning for free-play mode (not recommended)
# CLEARN_STRICT_FREE_PLAY=1

# ── Paths (rarely needed — defaults use project-relative paths) ─────
# Override TCC compiler path
# CLEARN_TCC_PATH=C:/tools/tcc/tcc.exe

# Override content directory path
# CLEARN_CONTENT_DIR=./content
